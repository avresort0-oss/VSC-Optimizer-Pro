{
  "name": "vsc-optimizer",
  "displayName": "VSC Optimizer Pro",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vsc-optimizer-sidebar",
          "title": "Optimizer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vsc-optimizer-sidebar": [
        {
          "type": "webview",
          "id": "vsc-optimizer-view",
          "name": "Power Panel"
        }
      ]
    }
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/vscode": "^1.75.0",
    "ts-loader": "^9.4.0",
    "typescript": "^4.9.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  }
}